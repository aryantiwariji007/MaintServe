# MaintServe Configuration

# Application
APP_NAME=MaintServe
DEBUG=false
API_PREFIX=/api/v1

# vLLM Backend
VLLM_BASE_URL=http://localhost:11434
VLLM_TIMEOUT=300.0
DEFAULT_MODEL=qwen3-vl

# Database
DATABASE_URL=postgresql+asyncpg://maintserve:maintserve@localhost:5432/maintserve

# Redis
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Admin
ADMIN_API_KEY=change-me-in-production

# Metrics
ENABLE_METRICS=true
